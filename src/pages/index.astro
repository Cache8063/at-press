---
import Base from "../layouts/Base.astro";
import { getBlogEntries, getProfile, getAbout, getBlueskyFeed } from "../lib/pds";
import { HANDLE, SESSION_DID_COOKIE } from "../lib/constants";
import { isOwner } from "../lib/auth";
import { formatDate, excerpt, relativeTime, bskyPostUrl } from "../lib/utils";
import { marked } from "marked";
import DOMPurify from "isomorphic-dompurify";

const profile = await getProfile();
const allEntries = await getBlogEntries();
const aboutRaw = await getAbout();
const feedPosts = await getBlueskyFeed(3);

// Pagination
const POSTS_PER_PAGE = 5;
const pageParam = Astro.url.searchParams.get("page");
const currentPage = Math.max(1, parseInt(pageParam || "1", 10) || 1);
const totalPages = Math.max(1, Math.ceil(allEntries.length / POSTS_PER_PAGE));
const page = Math.min(currentPage, totalPages);
const entries = allEntries.slice((page - 1) * POSTS_PER_PAGE, page * POSTS_PER_PAGE);

const aboutHtml = DOMPurify.sanitize(await marked.parse(aboutRaw), {
  ADD_ATTR: ["target"],
});

const sessionDid = Astro.cookies.get(SESSION_DID_COOKIE)?.value;
const isAuthor = sessionDid ? isOwner(sessionDid) : false;
---

<Base title="bkb — writing" description={profile.description || "Writing by bkb on the AT Protocol"} maxWidth="max-w-5xl">
  <div class="grid grid-cols-1 md:grid-cols-[200px_1fr] lg:grid-cols-[200px_1fr_220px] gap-8 md:gap-10 fade-in">
    <!-- Profile sidebar -->
    <aside class="md:sticky md:top-8 md:self-start">
      <div class="border border-border/50 rounded-lg p-4 md:p-5">
        <div class="flex flex-row md:flex-col items-center md:items-start gap-4 md:gap-0">
          {profile.avatarUrl && (
            <img
              src={profile.avatarUrl}
              alt={profile.displayName}
              class="w-16 h-16 md:w-20 md:h-20 rounded-full object-cover avatar-glow md:mb-4"
            />
          )}
          <div class="md:w-full">
            <h1 class="font-serif text-2xl md:text-xl font-bold text-ink-bright">{profile.displayName}</h1>
            <p class="text-base md:text-xs text-muted font-mono">@{HANDLE}</p>
          </div>
        </div>
        {profile.description && (
          <p class="text-muted text-base md:text-sm leading-relaxed mt-3 line-clamp-2 md:line-clamp-none whitespace-pre-line">{profile.description}</p>
        )}
        <div class="hidden md:flex flex-col gap-1.5 mt-4 text-sm">
          <button
            id="about-trigger"
            class="text-left text-accent hover:text-accent-light transition-colors cursor-pointer"
          >
            about this blog
          </button>
          <a
            href={`https://bsky.app/profile/${HANDLE}`}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Bluesky profile (opens in new tab)"
            class="text-muted hover:text-ink transition-colors"
          >
            bluesky &rarr;
          </a>
        </div>
        <!-- Mobile: compact about link -->
        <button
          id="about-trigger-mobile"
          class="md:hidden text-base text-accent hover:text-accent-light transition-colors cursor-pointer mt-2"
        >
          about this blog
        </button>
      </div>
    </aside>

    <!-- Post list -->
    <div>
      {entries.length === 0 ? (
        <p class="text-muted italic font-serif fade-in-delay">No entries yet.</p>
      ) : (
        <div class="space-y-4 stagger-in">
          {entries.map((entry) => (
            <article>
              <a href={`/${entry.rkey}`} class="group block py-5 px-4 sm:px-5 rounded-lg border border-border/30 hover:border-accent/30 hover:bg-paper-raised card-glow">
                <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 sm:gap-4">
                  <h2 class="font-serif text-xl md:text-xl font-semibold text-ink-bright group-hover:text-accent transition-colors">
                    {entry.title}
                  </h2>
                  <time
                    datetime={entry.createdAt}
                    class="text-sm font-mono text-muted shrink-0"
                  >
                    {formatDate(entry.createdAt)}
                  </time>
                </div>
                <p class="text-muted text-base md:text-base leading-relaxed mt-2 font-serif">
                  {excerpt(entry.content)}
                </p>
              </a>
            </article>
          ))}
        </div>
      )}

      {/* Pagination */}
      {totalPages > 1 && (
        <nav aria-label="Blog pagination" class="flex items-center justify-center gap-2 mt-8 font-mono text-sm">
          {page > 1 && (
            <a href={page === 2 ? "/" : `/?page=${page - 1}`} class="text-muted hover:text-accent transition-colors px-2 py-1">&larr; prev</a>
          )}
          {Array.from({ length: totalPages }, (_, i) => i + 1).map((p) => (
            p === page ? (
              <span class="text-accent font-bold px-2 py-1">{p}</span>
            ) : (
              <a href={p === 1 ? "/" : `/?page=${p}`} class="text-muted hover:text-accent transition-colors px-2 py-1">{p}</a>
            )
          ))}
          {page < totalPages && (
            <a href={`/?page=${page + 1}`} class="text-muted hover:text-accent transition-colors px-2 py-1">next &rarr;</a>
          )}
        </nav>
      )}

      {/* Bluesky feed — mobile only (shown below posts on small screens) */}
      {feedPosts.length > 0 && (
        <section class="lg:hidden mt-10 pt-8 border-t border-border/30 fade-in-delay">
          <h2 class="font-mono text-xs text-muted uppercase tracking-wider mb-4">recent on bluesky</h2>
          <div class="space-y-3">
            {feedPosts.map((post) => (
              <a
                href={bskyPostUrl(post.uri, HANDLE)}
                target="_blank"
                rel="noopener noreferrer"
                class="group block py-3 px-4 rounded-lg border border-border/30 hover:border-accent/30 hover:bg-paper-raised card-glow"
              >
                <p class="font-serif text-sm text-ink leading-relaxed whitespace-pre-line line-clamp-3">{post.text}</p>
                <div class="flex items-center gap-3 mt-2 text-xs font-mono text-muted">
                  <time datetime={post.createdAt}>{relativeTime(post.createdAt)}</time>
                  {post.likeCount > 0 && <span>{post.likeCount} likes</span>}
                </div>
              </a>
            ))}
          </div>
        </section>
      )}
    </div>

    {/* Bluesky feed — desktop right sidebar */}
    {feedPosts.length > 0 && (
      <aside class="hidden lg:block lg:sticky lg:top-8 lg:self-start fade-in-delay">
        <h2 class="font-mono text-xs text-muted uppercase tracking-wider mb-4">recent on bluesky</h2>
        <div class="space-y-3">
          {feedPosts.map((post) => (
            <a
              href={bskyPostUrl(post.uri, HANDLE)}
              target="_blank"
              rel="noopener noreferrer"
              class="group block py-3 px-3 rounded-lg border border-border/30 hover:border-accent/30 hover:bg-paper-raised card-glow"
            >
              <p class="font-serif text-sm text-ink leading-relaxed whitespace-pre-line line-clamp-4">{post.text}</p>
              {post.images.length > 0 && (
                <div class="mt-2 overflow-hidden rounded max-h-48">
                  <img
                    src={post.images[0].thumb}
                    alt={post.images[0].alt?.slice(0, 100) || ""}
                    class="w-full h-auto rounded object-cover"
                    loading="lazy"
                  />
                </div>
              )}
              <div class="flex items-center gap-3 mt-2 text-xs font-mono text-muted">
                <time datetime={post.createdAt}>{relativeTime(post.createdAt)}</time>
                {post.likeCount > 0 && <span>{post.likeCount}</span>}
                {post.repostCount > 0 && <span>{post.repostCount} rp</span>}
              </div>
            </a>
          ))}
        </div>
        <a
          href={`https://bsky.app/profile/${HANDLE}`}
          target="_blank"
          rel="noopener noreferrer"
          class="block mt-3 text-xs font-mono text-muted hover:text-accent transition-colors"
        >
          more on bluesky &rarr;
        </a>
      </aside>
    )}
  </div>

  <!-- About modal -->
  <div id="about-modal" class="about-overlay" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="about-title">
    <div class="about-backdrop"></div>
    <div class="about-panel">
      <div class="flex items-start justify-between mb-6">
        <h2 id="about-title" class="font-serif text-xl font-bold text-ink-bright">About</h2>
        <div class="flex items-center gap-3">
          {isAuthor && (
            <button id="about-edit-btn" type="button" aria-label="Edit about section" class="text-xs font-mono text-muted hover:text-accent transition-colors cursor-pointer">
              edit
            </button>
          )}
          <button id="about-close" type="button" aria-label="Close about dialog" class="text-muted hover:text-ink transition-colors cursor-pointer text-lg leading-none">&times;</button>
        </div>
      </div>
      <!-- View mode -->
      <div id="about-view" class="prose-about font-serif text-ink leading-relaxed" set:html={aboutHtml} />
      <!-- Edit mode (owner only) -->
      {isAuthor && (
        <div id="about-edit" class="hidden">
          <textarea
            id="about-textarea"
            aria-label="About section content"
            class="w-full h-64 bg-paper-dim border border-border rounded-lg p-3 font-serif text-ink text-sm leading-relaxed resize-y focus:outline-none focus:border-accent"
            placeholder="Write your about section (markdown supported)..."
          >{aboutRaw}</textarea>
          <div class="flex items-center justify-between mt-3">
            <p class="text-xs text-muted font-mono">markdown supported</p>
            <div class="flex gap-2">
              <button id="about-cancel" type="button" aria-label="Cancel editing about section" class="text-sm text-muted hover:text-ink transition-colors cursor-pointer px-3 py-1">
                cancel
              </button>
              <button id="about-save" type="button" aria-label="Save about section" class="text-sm text-accent hover:text-accent-light transition-colors cursor-pointer px-3 py-1 border border-accent/30 rounded">
                save
              </button>
            </div>
          </div>
        </div>
      )}
    </div>
  </div>
</Base>

<script>
  function initAboutModal() {
    const modal = document.getElementById("about-modal");
    const triggers = [
      document.getElementById("about-trigger"),
      document.getElementById("about-trigger-mobile"),
    ];
    const closeBtn = document.getElementById("about-close");
    const backdrop = modal?.querySelector(".about-backdrop");

    const viewEl = document.getElementById("about-view");
    const editEl = document.getElementById("about-edit");
    const editBtn = document.getElementById("about-edit-btn");
    const textarea = document.getElementById("about-textarea") as HTMLTextAreaElement | null;
    const saveBtn = document.getElementById("about-save");
    const cancelBtn = document.getElementById("about-cancel");

    if (!modal) return;

    let triggerEl: HTMLElement | null = null;

    function getFocusableElements(): HTMLElement[] {
      return Array.from(
        modal!.querySelectorAll<HTMLElement>(
          'button:not([disabled]), [href], input:not([disabled]), textarea:not([disabled]), [tabindex]:not([tabindex="-1"])'
        )
      ).filter((el) => el.offsetParent !== null);
    }

    function trapFocus(e: KeyboardEvent) {
      if (e.key !== "Tab") return;
      const focusable = getFocusableElements();
      if (focusable.length === 0) return;
      const first = focusable[0];
      const last = focusable[focusable.length - 1];
      if (e.shiftKey) {
        if (document.activeElement === first) { e.preventDefault(); last.focus(); }
      } else {
        if (document.activeElement === last) { e.preventDefault(); first.focus(); }
      }
    }

    function open() {
      triggerEl = document.activeElement as HTMLElement;
      modal!.classList.add("is-open");
      modal!.setAttribute("aria-hidden", "false");
      document.body.style.overflow = "hidden";
      // Focus first focusable element in modal
      requestAnimationFrame(() => {
        const focusable = getFocusableElements();
        if (focusable.length > 0) focusable[0].focus();
      });
      document.addEventListener("keydown", trapFocus);
    }

    function close() {
      modal!.classList.remove("is-open");
      modal!.setAttribute("aria-hidden", "true");
      document.body.style.overflow = "";
      document.removeEventListener("keydown", trapFocus);
      showView();
      triggerEl?.focus();
    }

    function showView() {
      viewEl?.classList.remove("hidden");
      editEl?.classList.add("hidden");
      if (editBtn) editBtn.textContent = "edit";
    }

    function showEdit() {
      viewEl?.classList.add("hidden");
      editEl?.classList.remove("hidden");
      if (editBtn) editBtn.textContent = "viewing";
      textarea?.focus();
    }

    triggers.forEach((btn) => btn?.addEventListener("click", open));
    closeBtn?.addEventListener("click", close);
    backdrop?.addEventListener("click", close);

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && modal!.classList.contains("is-open")) close();
    });

    // Edit toggle
    editBtn?.addEventListener("click", () => {
      if (editEl?.classList.contains("hidden")) {
        showEdit();
      } else {
        showView();
      }
    });

    cancelBtn?.addEventListener("click", showView);

    // Save
    saveBtn?.addEventListener("click", async () => {
      if (!textarea) return;

      const content = textarea.value.trim();
      if (!content) {
        alert("About content cannot be empty.");
        return;
      }

      saveBtn.textContent = "saving...";
      (saveBtn as HTMLButtonElement).disabled = true;

      try {
        const res = await fetch("/api/about", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ content }),
        });

        const data = await res.json();
        if (data.success) {
          window.location.reload();
        } else {
          alert(data.error || "Save failed");
          saveBtn.textContent = "save";
          (saveBtn as HTMLButtonElement).disabled = false;
        }
      } catch {
        alert("Network error");
        saveBtn.textContent = "save";
        (saveBtn as HTMLButtonElement).disabled = false;
      }
    });
  }

  initAboutModal();
</script>
