---
import "../styles/global.css";
import { BLOG_URL, HANDLE, THEME_COLORS, DEFAULT_THEME_COLOR } from "../lib/constants";

interface Props {
  title: string;
  description?: string;
  wide?: boolean;
  maxWidth?: string;
}

const { title, description = "Writing by bkb", wide = false, maxWidth } = Astro.props;
const widthClass = maxWidth || (wide ? 'max-w-6xl' : 'max-w-2xl');
const canonicalUrl = new URL(Astro.url.pathname, BLOG_URL);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content={DEFAULT_THEME_COLOR} />
    <link rel="canonical" href={canonicalUrl.toString()} />
    <link rel="alternate" type="application/rss+xml" title="bkb — writing" href="/rss.xml" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="article" />
    <meta property="og:url" content={canonicalUrl.toString()} />
    <title>{title}</title>
    <script is:inline>
      (function(){var t=localStorage.getItem("blog-theme");if(t==="midnight"){localStorage.removeItem("blog-theme");t=null}if(!t||t==="eink"){document.documentElement.setAttribute("data-theme","eink")}else if(t!=="default"){document.documentElement.setAttribute("data-theme",t)}})();
    </script>
  </head>
  <body class="bg-paper text-ink min-h-screen">
    <a href="#main-content" class="skip-link">Skip to content</a>
    <header class="border-b border-gradient">
      <nav class={`${widthClass} mx-auto px-4 sm:px-6 py-4 sm:py-5 flex items-center justify-between`}>
        <a href="/" class="logo-link hover:opacity-80 transition-opacity" aria-label="bkb home">
          <!-- Text logo (non-eink themes) -->
          <span class="logo-text font-serif text-xl font-bold tracking-tight text-gradient">bkb</span>
          <!-- Dot matrix logo (eink theme) -->
          <svg class="logo-dots" width="56" height="18" viewBox="0 0 56 18" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <!-- b -->
            <circle cx="2" cy="2" r="1.5" fill="currentColor"/><circle cx="6" cy="2" r="1.5" fill="currentColor"/><circle cx="10" cy="2" r="1.5" fill="currentColor"/><circle cx="14" cy="2" r="1.2" fill="currentColor" opacity="0.2"/>
            <circle cx="2" cy="6" r="1.5" fill="currentColor"/><circle cx="14" cy="6" r="1.5" fill="currentColor"/>
            <circle cx="2" cy="10" r="1.5" fill="currentColor"/><circle cx="6" cy="10" r="1.5" fill="currentColor"/><circle cx="10" cy="10" r="1.5" fill="currentColor"/><circle cx="14" cy="10" r="1.2" fill="currentColor" opacity="0.2"/>
            <circle cx="2" cy="14" r="1.5" fill="currentColor"/><circle cx="14" cy="14" r="1.5" fill="currentColor"/>
            <circle cx="2" cy="18" r="1.5" fill="currentColor"/><circle cx="6" cy="18" r="1.5" fill="currentColor"/><circle cx="10" cy="18" r="1.5" fill="currentColor"/><circle cx="14" cy="18" r="1.2" fill="currentColor" opacity="0.2"/>
            <!-- k -->
            <circle cx="22" cy="2" r="1.5" fill="currentColor"/><circle cx="34" cy="2" r="1.5" fill="currentColor"/>
            <circle cx="22" cy="6" r="1.5" fill="currentColor"/><circle cx="30" cy="6" r="1.5" fill="currentColor"/>
            <circle cx="22" cy="10" r="1.5" fill="currentColor"/><circle cx="26" cy="10" r="1.5" fill="currentColor"/>
            <circle cx="22" cy="14" r="1.5" fill="currentColor"/><circle cx="30" cy="14" r="1.5" fill="currentColor"/>
            <circle cx="22" cy="18" r="1.5" fill="currentColor"/><circle cx="34" cy="18" r="1.5" fill="currentColor"/>
            <!-- b -->
            <circle cx="42" cy="2" r="1.5" fill="currentColor"/><circle cx="46" cy="2" r="1.5" fill="currentColor"/><circle cx="50" cy="2" r="1.5" fill="currentColor"/><circle cx="54" cy="2" r="1.2" fill="currentColor" opacity="0.2"/>
            <circle cx="42" cy="6" r="1.5" fill="currentColor"/><circle cx="54" cy="6" r="1.5" fill="currentColor"/>
            <circle cx="42" cy="10" r="1.5" fill="currentColor"/><circle cx="46" cy="10" r="1.5" fill="currentColor"/><circle cx="50" cy="10" r="1.5" fill="currentColor"/><circle cx="54" cy="10" r="1.2" fill="currentColor" opacity="0.2"/>
            <circle cx="42" cy="14" r="1.5" fill="currentColor"/><circle cx="54" cy="14" r="1.5" fill="currentColor"/>
            <circle cx="42" cy="18" r="1.5" fill="currentColor"/><circle cx="46" cy="18" r="1.5" fill="currentColor"/><circle cx="50" cy="18" r="1.5" fill="currentColor"/><circle cx="54" cy="18" r="1.2" fill="currentColor" opacity="0.2"/>
          </svg>
        </a>
        <div class="flex items-center gap-4 sm:gap-5 text-sm text-muted">
          <a href="/write" class="hover:text-accent transition-colors">write</a>
          <a
            href={`https://bsky.app/profile/${HANDLE}`}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Bluesky profile (opens in new tab)"
            class="hover:text-ink transition-colors"
          >
            bluesky
          </a>
          <a
            href="/rss.xml"
            class="hover:text-ink transition-colors"
          >
            rss
          </a>
        </div>
      </nav>
    </header>

    <main id="main-content" class={`mx-auto px-4 sm:px-6 py-8 sm:py-12 ${widthClass}`}>
      <slot />
    </main>

    <footer class="border-t border-gradient mt-16">
      <div class={`${widthClass} mx-auto px-4 sm:px-6 py-8 flex flex-col sm:flex-row items-center sm:justify-between gap-4 text-sm text-muted`}>
        <p class="text-center sm:text-left">
          powered by <a href="https://atproto.com" target="_blank" rel="noopener" class="text-accent/70 hover:text-accent transition-colors">AT Protocol</a>
          <span class="text-border-light mx-2">&middot;</span>
          served from <a href="https://arcnode.xyz" class="text-accent/70 hover:text-accent transition-colors">arcnode.xyz</a>
        </p>
        <div id="theme-selector" role="group" aria-label="Theme selector" class="flex items-center gap-1.5">
          {Object.entries(THEME_COLORS).map(([name, color]) => (
            <button data-set-theme={name} aria-label={`Switch to ${name} theme`} class="theme-dot w-4 h-4 rounded-full border border-border-light transition-transform hover:scale-125" style={`background: ${color};`}></button>
          ))}
        </div>
      </div>
    </footer>

    <script>
      import { THEME_COLORS, THEME_STORAGE_KEY } from "../lib/constants";

      function applyTheme(theme: string) {
        if (!theme || theme === "default" || theme === "midnight") {
          document.documentElement.removeAttribute("data-theme");
          theme = "default";
        } else {
          document.documentElement.setAttribute("data-theme", theme);
        }
        const meta = document.querySelector('meta[name="theme-color"]');
        if (meta) meta.setAttribute("content", THEME_COLORS[theme] || THEME_COLORS.default);
        document.querySelectorAll(".theme-dot").forEach((dot) => {
          const btn = dot as HTMLButtonElement;
          const isActive = btn.dataset.setTheme === theme;
          btn.style.transform = isActive ? "scale(1.35)" : "";
          btn.style.boxShadow = isActive ? "0 0 0 2px var(--color-accent)" : "";
        });
        localStorage.setItem(THEME_STORAGE_KEY, theme);
      }

      // Apply saved theme immediately (eink is the default)
      const saved = localStorage.getItem(THEME_STORAGE_KEY);
      applyTheme(saved || "eink");

      // Bind click handlers
      document.querySelectorAll("[data-set-theme]").forEach((btn) => {
        btn.addEventListener("click", () => {
          applyTheme((btn as HTMLElement).dataset.setTheme || "default");
        });
      });

      // E-ink navigation flash: intercept internal link clicks
      function isEink() {
        return document.documentElement.getAttribute("data-theme") === "eink";
      }

      document.addEventListener("click", (e) => {
        if (!isEink()) return;
        const link = (e.target as HTMLElement).closest("a[href]") as HTMLAnchorElement | null;
        if (!link) return;
        // Only intercept same-origin, non-external, non-hash links
        if (link.target === "_blank" || link.origin !== location.origin) return;
        if (link.getAttribute("href")?.startsWith("#")) return;

        e.preventDefault();
        const url = link.href;
        document.body.classList.add("eink-navigating");
        setTimeout(() => { window.location.href = url; }, 250);
      });
    </script>
  </body>
</html>
