# AT Protocol PDS app password (create at arcnode.xyz Settings > App Passwords)
PDS_APP_PASSWORD=

# ATAuth gateway URL (Docker override in docker-compose.yml)
# ATAUTH_GATEWAY_URL=https://apricot.workingtitle.zip

# ATAuth public URL (browser-facing, for redirects)
# ATAUTH_PUBLIC_URL=https://apricot.workingtitle.zip

# SQLite database path for drafts (default: /data/drafts.db)
# DRAFTS_DB_PATH=/data/drafts.db
