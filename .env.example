# Required: Your AT Protocol identity
PDS_URL=https://your-pds.example.com
DID=did:plc:your-did-here
HANDLE=you.your-pds.example.com
PDS_APP_PASSWORD=

# Required: Blog URL (where this blog is hosted)
BLOG_URL=https://blog.example.com

# Optional: ATAuth gateway for login/editing
# ATAUTH_GATEWAY_URL=https://your-atauth-instance.example.com
# ATAUTH_PUBLIC_URL=https://your-atauth-instance.example.com

# Optional: Lexicon collections (defaults to WhiteWind)
# BLOG_COLLECTION=com.whtwnd.blog.entry
# ABOUT_COLLECTION=xyz.arcnode.blog.about

# Optional: SQLite draft storage path
# DRAFTS_DB_PATH=/data/drafts.db
